<!DOCTYPE html>
<html lang="no">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Service Logg</title>

<style>
body { font-family: system-ui; background:#f5f5f5; padding:16px; }

.tab-buttons { display:flex; gap:8px; margin-bottom:10px; }
button { padding:10px; border:none; background:black; color:white; }

.hidden { display:none; }

table { border-collapse: collapse; width:100%; background:white; }
th, td { border:1px solid #ccc; padding:6px; text-align:center; }

th { background:#f57c00; color:white; }

.section { background:#1e88e5; color:white; }
.sub { background:#eee; text-align:left; }

.yellow { background:#fff176; text-align:left; }
.bluecell { background:#4dd0e1; }

input.inline {
  width:100%;
  border:none;
  background:transparent;
  font-weight:bold;
  color:white;
}

select.inline {
  width:100%;
  border:none;
  background:transparent;
  color:white;
  font-weight:bold;
}
textarea { width:100%; height:120px; }
</style>
</head>

<body>

<div class="tab-buttons">
  <button onclick="showTab('tableTab')">📋 Service</button>
  <button onclick="showTab('settingsTab')">⚙️ Datavalg</button>
</div>

<div id="tableTab"></div>

<div id="settingsTab" class="hidden">
  <h3>Seksjoner (blå linjer dropdown)</h3>
  <textarea id="sectionList"></textarea>

  <h3>Utført av dropdown</h3>
  <textarea id="utførtListe"></textarea>

  <button onclick="saveSettings()">Lagre datavalg</button>

  <hr>

  <h3>Legg til ny seksjon</h3>
  <button onclick="addSection()">➕ Ny blå linje</button>

  <h3>Legg til rad</h3>
  <input id="newRowName" placeholder="Navn på rad">
  <button onclick="addRow()">➕ Legg til rad</button>
</div>

<script>
let data = JSON.parse(localStorage.getItem('service_data') || 'null');
let settings = JSON.parse(localStorage.getItem('service_settings') || 'null');

if(!settings){
  settings = {
    sections:["Motor","Smøring","Kontroll","Kommentar"],
    utfort:["Magnar","Verksted","Selv"]
  };
}

if(!data){
  data = {
    headers:["53,1","110","172"],
    rows:[
      {type:"section", label:"Motor"},
      {label:"Olje/Olje-filter", values:["✔","✔","✔"]},
      {label:"Luft-filter", values:["✔","✔","✔"]},

      {type:"section", label:"Kommentar"},
      {label:"Kommentar", values:["","",""], comment:true},

      {type:"section", label:"Utført av"},
      {label:"Utført av", values:["","",""], dropdown:true}
    ]
  };
}

function showTab(tab){
  document.getElementById('tableTab').classList.add('hidden');
  document.getElementById('settingsTab').classList.add('hidden');
  document.getElementById(tab).classList.remove('hidden');
}

function render(){
  const el = document.getElementById('tableTab');
  el.innerHTML = '';

  let html = '<table>';

  // header
  html += '<tr><th>Timer</th>';
  data.headers.forEach((h,i)=>{
    html += `<th contenteditable oninput="updateHeader(${i},this.innerText)">${h}</th>`;
  });
  html += '</tr>';

  data.rows.forEach((row,r)=>{

    // 🔵 SECTION MED DROPDOWN
    if(row.type==="section"){
      html += `<tr>
        <td colspan="${data.headers.length+1}" class="section">
          <select class="inline" onchange="updateSection(${r},this.value)">
            ${settings.sections.map(s=>`
              <option ${row.label===s?'selected':''}>${s}</option>
            `).join('')}
          </select>
        </td>
      </tr>`;
      return;
    }

    html += `<tr><td class="sub">
      <input value="${row.label}" 
      oninput="updateLabel(${r},this.value)">
    </td>`;

    row.values.forEach((val,c)=>{

      if(row.comment){
        html += `<td class="yellow" contenteditable
          oninput="updateCell(${r},${c},this.innerText)">${val}</td>`;
      }

      else if(row.dropdown){
        html += `<td class="bluecell">
          <select onchange="updateCell(${r},${c},this.value)">
            <option value="">Velg</option>
            ${settings.utfort.map(v=>`
              <option ${val===v?'selected':''}>${v}</option>
            `).join('')}
          </select>
        </td>`;
      }

      else{
        html += `<td onclick="toggle(${r},${c})">${val==="✔"?"✔":""}</td>`;
      }

    });

    html += '</tr>';
  });

  html += '</table>';
  el.innerHTML = html;

  localStorage.setItem('service_data', JSON.stringify(data));
}

function toggle(r,c){
  data.rows[r].values[c] = data.rows[r].values[c]==="✔"?"":"✔";
  render();
}

function updateCell(r,c,val){
  data.rows[r].values[c]=val;
  save();
}

function updateLabel(r,val){
  data.rows[r].label=val;
  save();
}

function updateSection(r,val){
  data.rows[r].label=val;
  save();
}

function updateHeader(i,val){
  data.headers[i]=val;
  save();
}

function save(){
  localStorage.setItem('service_data', JSON.stringify(data));
}

function addSection(){
  data.rows.push({type:"section", label:settings.sections[0]});
  render();
}

function addRow(){
  const name = document.getElementById('newRowName').value;
  if(!name) return;

  data.rows.push({
    label:name,
    values:Array(data.headers.length).fill("")
  });

  render();
}

function saveSettings(){
  settings.sections = document.getElementById('sectionList').value
    .split('\n').map(v=>v.trim()).filter(Boolean);

  settings.utfort = document.getElementById('utførtListe').value
    .split('\n').map(v=>v.trim()).filter(Boolean);

  localStorage.setItem('service_settings', JSON.stringify(settings));
  render();
}

function init(){
  document.getElementById('sectionList').value = settings.sections.join('\n');
  document.getElementById('utførtListe').value = settings.utfort.join('\n');
  render();
}

init();
</script>

</body>
</html>
